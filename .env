# Local PostgreSQL example
# Create a local DB and replace credentials as needed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voicedesk?schema=public"

# AI provider switch
AI_PROVIDER_MODE="external_free"

# External free provider (OpenRouter example)
OPENROUTER_API_KEY=""
EXTERNAL_FREE_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# Self-hosted provider (Ollama/local endpoint)
SELF_HOSTED_AI_URL="http://localhost:11434"
SELF_HOSTED_AI_MODEL="llama3.1"
